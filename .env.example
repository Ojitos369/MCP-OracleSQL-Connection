# Credenciales de conexión a Oracle SQL (vista de producción).
# Copia este archivo a .env y rellena los valores reales.
DB_SCHEME_PROD_VIEW=        # service name / SID de Oracle
DB_HOST_PROD_VIEW=          # host  ó  host:puerto  (puerto por defecto 1521)
DB_USER_PROD_VIEW=
DB_PASSWORD_PROD_VIEW=

# Esquema Oracle que contiene los objetos (ej. CL). Si queda vacío,
# las tablas se consultan SIN prefijo de esquema (se usa user_tables / user_views
# del usuario conectado en lugar de all_tables / all_views).
DB_SCHEMA=

# --- Host / puerto donde escucha el MCP (Streamable HTTP) ---
# MCP_PORT es OBLIGATORIO (sin valor por defecto). MCP_HOST por defecto 0.0.0.0.
MCP_HOST=
MCP_PORT=8381

# --- Auth opción A: token compartido (Bearer / X-API-Key / ?token=) ---
# Genera uno con: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Vacío => este modo no se usa.
MCP_AUTH_TOKEN=

# --- Auth opción B: OAuth 2.1 (authorization_code + PKCE) ---
# Valores que se pegan en "OAuth Client ID" / "OAuth Client Secret" del dialog
# "Add custom connector". Genera con:
#   python3 -c "import secrets; print(secrets.token_urlsafe(8))"   # parte del id
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"  # secret
# Si OAUTH_CLIENT_ID queda vacío, igual funciona el registro dinámico (DCR).
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
# Allow-list de redirect_uris para ese client (coma-separado). Vacío => cualquier https://.
OAUTH_REDIRECT_URIS=
# Clave para firmar los tokens emitidos (HMAC-SHA256). Vacío => usa MCP_AUTH_TOKEN.
OAUTH_SIGNING_KEY=

# Nota: la autenticación queda ACTIVA si defines MCP_AUTH_TOKEN y/o OAUTH_CLIENT_ID.
# Si ambos quedan vacíos, el server arranca SIN auth.
URL=